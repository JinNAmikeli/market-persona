{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "api/agent_briefing_response.schema.json",
  "title": "AgentBriefingResponse",
  "type": "object",
  "required": [
    "trace_id",
    "title",
    "briefing_type",
    "style",
    "script",
    "sections",
    "evidence",
    "risk_flags",
    "next_watch",
    "review"
  ],
  "properties": {
    "trace_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "briefing_type": {
      "type": "string"
    },
    "style": {
      "type": "string"
    },
    "script": {
      "type": "string"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "content"],
        "properties": {
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_watch": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review": {
      "type": "object",
      "required": [
        "passed",
        "factuality",
        "compliance",
        "clarity",
        "blocked_terms",
        "repair_suggestions",
        "issues",
        "layers"
      ],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "factuality": {
          "type": "object",
          "required": [
            "status",
            "summary",
            "checked_claims",
            "supported_claims",
            "unsupported_claims",
            "conflicting_claims",
            "evidence_count",
            "coverage"
          ],
          "properties": {
            "status": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            },
            "checked_claims": {
              "type": "integer"
            },
            "supported_claims": {
              "type": "integer"
            },
            "unsupported_claims": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "conflicting_claims": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "evidence_count": {
              "type": "integer"
            },
            "coverage": {
              "type": "string"
            },
            "coverage_summary": {
              "type": "string"
            },
            "required_evidence_types": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "claim_bindings": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["claim", "claim_type", "status", "evidence_refs", "reason"],
                "properties": {
                  "claim": {
                    "type": "string"
                  },
                  "claim_type": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string"
                  },
                  "evidence_refs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "reason": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "compliance": {
          "type": "string"
        },
        "clarity": {
          "type": "string"
        },
        "blocked_terms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "repair_suggestions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "layers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "mode", "passed"]
          }
        }
      }
    }
  },
  "additionalProperties": true
}
