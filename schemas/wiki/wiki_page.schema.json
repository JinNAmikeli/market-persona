{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wiki/wiki_page.schema.json",
  "title": "WikiPage",
  "type": "object",
  "required": [
    "topic_id",
    "title",
    "version",
    "status",
    "reviewed_at",
    "evidence_quality",
    "sources",
    "tags",
    "applicable_tasks",
    "forbidden_use",
    "sections"
  ],
  "properties": {
    "topic_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "reviewed", "deprecated"]
    },
    "reviewed_at": {
      "type": ["string", "null"]
    },
    "evidence_quality": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "source", "title", "url"],
        "properties": {
          "type": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "url": {
            "type": ["string", "null"]
          },
          "accessed_at": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": true
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "applicable_tasks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_use": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["section_id", "title", "content", "evidence", "updated_at"],
        "properties": {
          "section_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "source", "title", "url"],
              "properties": {
                "type": {
                  "type": "string"
                },
                "source": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "url": {
                  "type": ["string", "null"]
                },
                "accessed_at": {
                  "type": ["string", "null"]
                }
              },
              "additionalProperties": true
            }
          },
          "updated_at": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
