{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wiki/wiki_page.schema.json",
  "title": "WikiPage",
  "type": "object",
  "required": [
    "topic_id",
    "title",
    "version",
    "status",
    "tags",
    "applicable_tasks",
    "forbidden_use",
    "sections"
  ],
  "properties": {
    "topic_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "applicable_tasks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_use": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["section_id", "title", "content", "evidence", "updated_at"]
      }
    }
  },
  "additionalProperties": true
}
