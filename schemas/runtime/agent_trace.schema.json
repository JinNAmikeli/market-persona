{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime/agent_trace.schema.json",
  "title": "AgentTrace",
  "type": "object",
  "required": [
    "trace_id",
    "created_at",
    "request",
    "state_summary",
    "plan",
    "tool_results",
    "wiki_hits",
    "execution",
    "draft",
    "repair",
    "review",
    "memory_patch",
    "final_response"
  ],
  "properties": {
    "trace_id": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "request": {
      "type": "object",
      "required": ["user_id", "message", "mode", "context"],
      "properties": {
        "user_id": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "mode": {
          "type": "string"
        },
        "context": {
          "type": "object"
        }
      }
    },
    "state_summary": {
      "type": "object",
      "required": ["generated_at", "history_count", "memory"],
      "properties": {
        "generated_at": {
          "type": ["string", "null"]
        },
        "history_count": {
          "type": "integer"
        },
        "memory": {
          "type": "object",
          "required": [
            "watchlist",
            "focus_themes",
            "knowledge_level",
            "open_questions",
            "blockers",
            "next_priority",
            "journey_state",
            "risk_preferences"
          ],
          "properties": {
            "watchlist": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "focus_themes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "knowledge_level": {
              "type": "string"
            },
            "open_questions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "blockers": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "next_priority": {
              "type": "string"
            },
            "journey_state": {
              "type": "object",
              "required": ["stage", "active_task", "updated_from_task"]
            },
            "risk_preferences": {
              "type": "object",
              "required": ["needs_stronger_risk_warning"]
            }
          }
        }
      }
    },
    "plan": {
      "type": "object",
      "required": ["task_type", "intent", "required_tools", "knowledge_queries", "forbidden_outputs"],
      "properties": {
        "task_type": {
          "type": "string"
        },
        "intent": {
          "type": "string"
        },
        "required_tools": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "knowledge_queries": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "tool_results": {
      "type": "array",
      "items": {
        "$ref": "tool_result.schema.json"
      }
    },
    "wiki_hits": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "execution": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string"
        }
      }
    },
    "draft": {
      "type": "object",
      "required": ["task_type", "content", "evidence", "risk_flags", "next_watch", "execution"],
      "properties": {
        "task_type": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "risk_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_watch": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "execution": {
          "type": "object",
          "required": ["mode"]
        }
      }
    },
    "review": {
      "type": "object",
      "required": [
        "passed",
        "factuality",
        "compliance",
        "clarity",
        "blocked_terms",
        "repair_suggestions",
        "issues",
        "layers"
      ],
      "properties": {
        "passed": {
          "type": "boolean"
        },
        "factuality": {
          "type": "object",
          "required": [
            "status",
            "summary",
            "checked_claims",
            "supported_claims",
            "unsupported_claims",
            "conflicting_claims",
            "evidence_count",
            "coverage"
          ],
          "properties": {
            "status": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            },
            "checked_claims": {
              "type": "integer"
            },
            "supported_claims": {
              "type": "integer"
            },
            "unsupported_claims": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "conflicting_claims": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "evidence_count": {
              "type": "integer"
            },
            "coverage": {
              "type": "string"
            },
            "repair_status": {
              "type": "string"
            },
            "repaired_from_factuality": {
              "type": "object"
            },
            "coverage_summary": {
              "type": "string"
            },
            "required_evidence_types": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "claim_bindings": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["claim", "claim_type", "status", "evidence_refs", "reason"],
                "properties": {
                  "claim": {
                    "type": "string"
                  },
                  "claim_type": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string"
                  },
                  "evidence_refs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "reason": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "compliance": {
          "type": "string"
        },
        "clarity": {
          "type": "string"
        },
        "blocked_terms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "repair_suggestions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "layers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "mode", "passed"]
          }
        }
      }
    },
    "repair": {
      "type": "object",
      "required": [
        "mode",
        "changed",
        "pre_repair_content",
        "post_repair_content",
        "issues",
        "repair_suggestions",
        "replacements"
      ],
      "properties": {
        "mode": {
          "type": "string"
        },
        "changed": {
          "type": "boolean"
        },
        "pre_repair_content": {
          "type": ["string", "null"]
        },
        "post_repair_content": {
          "type": ["string", "null"]
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "repair_suggestions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "replacements": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "memory_patch": {
      "type": "object",
      "required": ["source", "reason", "confidence", "operations"],
      "properties": {
        "version": {
          "type": "integer"
        },
        "source": {
          "type": "string",
          "enum": ["user_message", "agent_response", "review"]
        },
        "reason": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "operations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["op", "path", "value", "source", "reason", "confidence"],
            "properties": {
              "op": {
                "type": "string",
                "enum": ["set", "append_unique", "prepend_unique"]
              },
              "path": {
                "type": "string"
              },
              "value": {},
              "source": {
                "type": "string",
                "enum": ["user_message", "agent_response", "review"]
              },
              "reason": {
                "type": "string"
              },
              "confidence": {
                "type": "string",
                "enum": ["low", "medium", "high"]
              }
            }
          }
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "updated_memory": {
      "type": "object"
    },
    "final_response": {
      "type": "object",
      "required": ["task_type", "content", "evidence", "risk_flags", "next_watch", "execution", "repair"],
      "properties": {
        "task_type": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "risk_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_watch": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "execution": {
          "type": "object",
          "required": ["mode"]
        },
        "repair": {
          "type": "object",
          "required": ["mode", "changed"]
        }
      }
    }
  },
  "additionalProperties": true
}
